{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user in the GLD Network tap game.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Telegram user ID" },
        "username": { "type": "string" },
        "first_name": { "type": "string" },
        "photo_url": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "multiplier": { "type": "number", "default": 0.1 },
        "airdropRank": { "type": "integer", "default": 0 },
        "energy": { "type": "integer", "default": 1000 },
        "daily_quest_states": { "type": "object", "default": {} },
        "last_claim_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "referred_by": { "type": "string" }
      },
      "required": ["id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage for user profiles"
    }
  }
}
