rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /users/{userId} {
      // Users can only see their own profile. Admin (Server) can see everything.
      // We allow list for the leaderboard if the user is signed in and the query filters strictly.
      // BUT for simplicity in this specific app, the leaderboard and user data are served via the backend.
      // So we can keep these rules very tight.
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if false; // All writes should go through the secure custom server
    }
  }
}
